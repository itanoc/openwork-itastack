{
  "$schema": "https://opencode.ai/config.json",
  // Copy this file to opencode.jsonc for local use.
  // Keep local credentials and machine-specific ports out of git.
  "mcp": {
    "openwork-browser": {
      "type": "remote",
      "url": "http://127.0.0.1:64883/mcp"
    },
    "chrome": {
      "type": "remote",
      "url": "http://127.0.0.1:64884/mcp"
    },
    "openwork-ui": {
      "type": "remote",
      "url": "http://127.0.0.1:64197/mcp"
    },
    "openwork-cloud": {
      "type": "remote",
      "enabled": false,
      "url": "https://app.openworklabs.com/api/den/mcp",
      "headers": {},
      "oauth": false
    }
  }
}
